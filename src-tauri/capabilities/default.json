{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capacites par defaut HIMYC Shell",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-kill",
    "shell:allow-open",
    "fs:default",
    "fs:scope-app-recursive",
    "fs:scope-appdata-recursive",
    "dialog:default",
    "dialog:allow-open",
    "core:path:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:*" },
        { "url": "http://127.0.0.1:*/*" },
        { "url": "http://localhost:*" },
        { "url": "http://localhost:*/*" }
      ]
    }
  ]
}
